  "header_subtitle": "\n                                                    <p style=\"margin: 0; font-family: Arial, Helvetica, sans-serif; font-size: 16px; color: #6B7280; line-height: 1.4;\">February 2026 Newsletter</p>\n                                                ",
  "header_tagline": "\n                                                    <p style=\"margin: 0; font-family: Georgia, 'Times New Roman', Times, serif; font-size: 14px; color: #6B7280; line-height: 1.5; font-style: italic;\">Strengthening community through service, leadership, and collaboration.</p>\n                                                ",
  "welcome_heading": "Welcome to 2026",
  "welcome_image": "\n                                                    <img src=\"https://mcusercontent.com/c4247c59958d5b480b1e708d2/_thumbs/9ddc2324-6e48-5569-f1d1-ee5220d298ec.jpg\" alt=\"Scott MacCumbee, PE \u2014 Incoming Post President\" width=\"556\" style=\"display: block; width: 100%; max-width: 556px; height: auto; border: 0; border-radius: 4px;\">\n                                                ",
  "welcome_body": "\n                                        <p style=\"margin: 0 0 16px 0; font-family: Arial, Helvetica, sans-serif; font-size: 16px; color: #374151; line-height: 1.6;\">2026 is shaping up to be our biggest year yet. From a first-ever Industry Day with the Coast Guard to a multi-day AI &amp; Cybersecurity Summit this fall, we've got a full calendar and a lot to build together.</p>\n\n                                        <p style=\"margin: 0 0 16px 0; font-family: Arial, Helvetica, sans-serif; font-size: 16px; color: #374151; line-height: 1.6;\">We're also proud to welcome <strong>Scott MacCumbee, PE</strong> as our incoming Post President. Scott's leadership and dedication to strengthening the connection between military, government, and private-sector professionals will guide the Post into an exciting new chapter. Welcome, Scott!</p>\n                                        ",
  "welcome_closing": "\n                                        <p style=\"margin: 0; font-family: Arial, Helvetica, sans-serif; font-size: 16px; color: #374151; line-height: 1.6;\">And if you missed it \u2014 photos from our Holiday Gala are live! <a href=\"https://web.photocircleapp.com/circles/Cuu8h9cXv4RQpzV258cXdN\" style=\"color: #003478; text-decoration: underline; font-weight: bold;\">View the gallery &rarr;</a></p>\n                                        ",
