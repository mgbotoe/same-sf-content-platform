  "uscg_heading": "\n                                        <p style=\"margin: 0 0 8px 0; font-family: Arial, Helvetica, sans-serif; font-size: 12px; font-weight: bold; color: #CF4E38; line-height: 1.3; text-transform: uppercase; letter-spacing: 1.5px;\">SPOTLIGHT EVENT</p>\n                                        <h2 class=\"vcHeading\" style=\"margin: 0 0 8px 0; font-family: Georgia, 'Times New Roman', Times, serif; font-size: 24px; font-weight: bold; color: #003478; line-height: 1.3;\">USCG Industry Day &amp; Open House</h2>\n                                        <p style=\"margin: 0 0 20px 0; font-family: Arial, Helvetica, sans-serif; font-size: 14px; font-weight: bold; color: #374151; line-height: 1.5;\">Co-hosted by SAME San Francisco Post and U.S. Coast Guard Civil Engineering Unit Oakland</p>\n                                        ",
  "uscg_image": "\n                                                    <img src=\"https://mcusercontent.com/c4247c59958d5b480b1e708d2/images/e84224c9-231b-f94c-a0b7-4135bb7d0060.png\" alt=\"USCG Industry Day and Open House \u2014 March 12, 2026 \u2014 Free at CEU Oakland\" width=\"560\" style=\"display: block; width: 100%; max-width: 560px; height: auto; border: 0; border-radius: 4px;\">\n                                                ",
  "uscg_body": "\n                                        <p style=\"margin: 0 0 16px 0; font-family: Arial, Helvetica, sans-serif; font-size: 16px; color: #374151; line-height: 1.6;\">On March 12, we're bringing the A/E/C community inside Coast Guard Civil Engineering Unit Oakland for an afternoon of briefings, networking, and direct conversation with the people who plan and execute USCG construction and facilities projects.</p>\n\n                                        <p style=\"margin: 0 0 10px 0; font-family: Arial, Helvetica, sans-serif; font-size: 16px; font-weight: bold; color: #374151; line-height: 1.6;\">What you'll get:</p>\n                                        <table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" width=\"100%\" style=\"margin-bottom: 20px;\">\n                                            <tr>\n                                                <td style=\"padding: 0 0 8px 16px; font-family: Arial, Helvetica, sans-serif; font-size: 16px; color: #374151; line-height: 1.6;\">&#8226;&nbsp;&nbsp;A briefing on CEUO's structure and contracting process</td>\n                                            </tr>\n                                            <tr>\n                                                <td style=\"padding: 0 0 8px 16px; font-family: Arial, Helvetica, sans-serif; font-size: 16px; color: #374151; line-height: 1.6;\">&#8226;&nbsp;&nbsp;Panel discussion on upcoming opportunities</td>\n                                            </tr>\n                                            <tr>\n                                                <td style=\"padding: 0 0 8px 16px; font-family: Arial, Helvetica, sans-serif; font-size: 16px; color: #374151; line-height: 1.6;\">&#8226;&nbsp;&nbsp;Networking with branch chiefs and contracting personnel</td>\n                                            </tr>\n                                            <tr>\n                                                <td style=\"padding: 0 0 0 16px; font-family: Arial, Helvetica, sans-serif; font-size: 16px; color: #374151; line-height: 1.6;\">&#8226;&nbsp;&nbsp;Breakout sessions by opportunity area</td>\n                                            </tr>\n                                        </table>\n                                        ",
  "uscg_details": "\n                                                    <table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" width=\"100%\">\n                                                        <tr>\n                                                            <td style=\"padding: 0 0 6px 0; font-family: Arial, Helvetica, sans-serif; font-size: 15px; color: #374151; line-height: 1.5;\"><strong>Date:</strong> Thursday, March 12, 2026</td>\n                                                        </tr>\n                                                        <tr>\n                                                            <td style=\"padding: 0 0 6px 0; font-family: Arial, Helvetica, sans-serif; font-size: 15px; color: #374151; line-height: 1.5;\"><strong>Time:</strong> 2:00 PM &ndash; 5:00 PM</td>\n                                                        </tr>\n                                                        <tr>\n                                                            <td style=\"padding: 0 0 6px 0; font-family: Arial, Helvetica, sans-serif; font-size: 15px; color: #374151; line-height: 1.5;\"><strong>Location:</strong> Civil Engineering Unit Oakland</td>\n                                                        </tr>\n                                                        <tr>\n                                                            <td style=\"padding: 0 0 6px 0; font-family: Arial, Helvetica, sans-serif; font-size: 15px; color: #374151; line-height: 1.5;\"><strong>Cost:</strong> FREE</td>\n                                                        </tr>\n                                                        <tr>\n                                                            <td style=\"padding: 0; font-family: Arial, Helvetica, sans-serif; font-size: 15px; color: #374151; line-height: 1.5;\"><strong>After:</strong> No-host social</td>\n                                                        </tr>\n                                                    </table>\n                                                ",
