  "sponsor_col_4": "\n                                                    <img src=\"https://mcusercontent.com/c4247c59958d5b480b1e708d2/_thumbs/6c38c8d2-4f68-617c-7239-709760e61a79.jpg\" alt=\"Sponsor Logo\" width=\"160\" style=\"display: block; max-width: 160px; height: auto; border: 0; margin: 0 auto;\">\n                                                ",
  "sponsor_col_5": "\n                                                    <img src=\"https://mcusercontent.com/c4247c59958d5b480b1e708d2/_thumbs/6c38c8d2-4f68-617c-7239-709760e61a79.jpg\" alt=\"Sponsor Logo\" width=\"160\" style=\"display: block; max-width: 160px; height: auto; border: 0; margin: 0 auto;\">\n                                                ",
  "sponsors_closing": "\n                                        <p style=\"margin: 24px 0 0 0; font-family: Arial, Helvetica, sans-serif; font-size: 15px; color: #374151; line-height: 1.6; text-align: center;\">Interested in partnering with SAME SF? <a href=\"mailto:samesanfrancisco@gmail.com?subject=Sponsorship%20Inquiry\" style=\"color: #003478; text-decoration: underline; font-weight: bold;\">Let's talk &rarr;</a></p>\n                                        ",
  "member_spotlight": "\n                                        <p style=\"margin: 0 0 12px 0; font-family: Arial, Helvetica, sans-serif; font-size: 11px; font-weight: bold; color: #C41E3A; line-height: 1.3; text-transform: uppercase; letter-spacing: 1.5px;\">MEMBER SPOTLIGHT</p>\n                                        <p style=\"margin: 0; font-family: Arial, Helvetica, sans-serif; font-size: 15px; color: #374151; line-height: 1.6;\"><strong>Congratulations to Sam Lee</strong>, accepted into the <strong>SAME Academy of Fellows 2026</strong>! Sam's decades of service and leadership represent the very best of our Post.</p>\n                                    ",
  "honoring_service": "\n                                        <p style=\"margin: 0 0 12px 0; font-family: Arial, Helvetica, sans-serif; font-size: 11px; font-weight: bold; color: #C41E3A; line-height: 1.3; text-transform: uppercase; letter-spacing: 1.5px;\">HONORING SERVICE</p>\n                                        <p style=\"margin: 0 0 12px 0; font-family: Arial, Helvetica, sans-serif; font-size: 15px; color: #374151; line-height: 1.6;\">Coming up next week:</p>\n                                        <p style=\"margin: 0 0 8px 0; font-family: Arial, Helvetica, sans-serif; font-size: 15px; color: #374151; line-height: 1.6;\"><strong>March 5 &mdash; Seabee Birthday (84th)</strong></p>\n                                        <p style=\"margin: 0 0 12px 0; font-family: Arial, Helvetica, sans-serif; font-size: 15px; color: #374151; line-height: 1.6;\">Happy birthday to the Naval Construction Battalions. \"Can Do\" since 1942.</p>\n                                        <p style=\"margin: 0; font-family: Arial, Helvetica, sans-serif; font-size: 15px; color: #374151; line-height: 1.6;\">We're proud to stand alongside those who serve, lead, and build.</p>\n                                    ",
  "speakers_heading": "\n                                        <p style=\"margin: 0 0 8px 0; font-family: Arial, Helvetica, sans-serif; font-size: 12px; font-weight: bold; color: #C41E3A; line-height: 1.3; text-transform: uppercase; letter-spacing: 1.5px;\">GET INVOLVED</p>\n                                        <h2 class=\"vcHeading\" style=\"margin: 0 0 16px 0; font-family: Georgia, 'Times New Roman', Times, serif; font-size: 24px; font-weight: bold; color: #003478; line-height: 1.3;\">Share Your Expertise</h2>\n                                        ",
  "speakers_body": "\n                                        <p style=\"margin: 0 0 16px 0; font-family: Arial, Helvetica, sans-serif; font-size: 16px; color: #374151; line-height: 1.6;\">We're building our 2026 meeting calendar and looking for members who have a presentation, case study, or topic they'd like to share at an upcoming in-person meeting.</p>\n\n                                        <p style=\"margin: 0 0 16px 0; font-family: Arial, Helvetica, sans-serif; font-size: 16px; color: #374151; line-height: 1.6;\">Topics can range from A/E/C project stories and federal contracting lessons to STEM outreach and new technology. Format is flexible: short talks, panels, or deep dives.</p>\n\n                                        <p style=\"margin: 0 0 24px 0; font-family: Arial, Helvetica, sans-serif; font-size: 16px; color: #374151; line-height: 1.6;\">If you've got something worth sharing, we want to hear from you.</p>\n                                        ",
  "speakers_button": "\n                                                    <!--[if mso]>\n                                                    <v:roundrect xmlns:v=\"urn:schemas-microsoft-com:vml\" xmlns:w=\"urn:schemas-microsoft-com:office:word\" href=\"mailto:samesanfrancisco@gmail.com?subject=Presentation%20Submission\" style=\"height:48px;v-text-anchor:middle;width:220px;\" arcsize=\"50%\" fillcolor=\"#C41E3A\" stroke=\"f\">\n                                                        <w:anchorlock/>\n                                                        <center style=\"color:#ffffff;font-family:Arial,Helvetica,sans-serif;font-size:16px;font-weight:bold;\">Submit a Topic</center>\n                                                    </v:roundrect>\n                                                    <![endif]-->\n                                                    <!--[if !mso]><!-->\n                                                    <a class=\"vcBtnRed\" href=\"mailto:samesanfrancisco@gmail.com?subject=Presentation%20Submission\" style=\"display: inline-block; background-color: #C41E3A; color: #FFFFFF !important; font-family: Arial, Helvetica, sans-serif; font-size: 16px; font-weight: bold; text-decoration: none !important; padding: 14px 36px; border-radius: 24px; line-height: 1.2;\">Submit a Topic</a>\n                                                    <!--<![endif]-->\n                                                ",
  "new_members_heading": "\n                                        <p style=\"margin: 0 0 8px 0; font-family: Arial, Helvetica, sans-serif; font-size: 12px; font-weight: bold; color: #C41E3A; line-height: 1.3; text-transform: uppercase; letter-spacing: 1.5px;\">WELCOME ABOARD</p>\n                                        <h2 class=\"vcHeading\" style=\"margin: 0 0 16px 0; font-family: Georgia, 'Times New Roman', Times, serif; font-size: 24px; font-weight: bold; color: #003478; line-height: 1.3;\">New Members This Month</h2>\n                                        ",
  "new_members_body": "\n                                        <p style=\"margin: 0 0 16px 0; font-family: Arial, Helvetica, sans-serif; font-size: 16px; color: #374151; line-height: 1.6;\">We're excited to welcome the newest members of the SAME San Francisco Post family. If you see them around, say hello and help them feel at home.</p>\n                                        <p style=\"margin: 0 0 16px 0; font-family: Arial, Helvetica, sans-serif; font-size: 16px; color: #374151; line-height: 1.8;\">&#8226;&nbsp;&nbsp;<strong>Jane Smith</strong> &mdash; ABC Engineering<br>&#8226;&nbsp;&nbsp;<strong>John Doe</strong> &mdash; XYZ Construction<br>&#8226;&nbsp;&nbsp;<strong>Maria Garcia</strong> &mdash; US Army Corps of Engineers</p>\n                                        <p style=\"margin: 0; font-family: Arial, Helvetica, sans-serif; font-size: 14px; color: #6B7280; line-height: 1.5; font-style: italic;\">Know someone who should be part of our community? They can <a href=\"https://www.same.org/sf/\" style=\"color: #003478; text-decoration: underline;\">join our mailing list</a> to stay in the loop on events, opportunities, and ways to get involved.</p>\n                                        ",
  "new_members_button": "\n                                                    <!--[if mso]>\n                                                    <v:roundrect xmlns:v=\"urn:schemas-microsoft-com:vml\" xmlns:w=\"urn:schemas-microsoft-com:office:word\" href=\"https://www.same.org/membership-communities/join/\" style=\"height:48px;v-text-anchor:middle;width:240px;\" arcsize=\"50%\" fillcolor=\"#C41E3A\" stroke=\"f\">\n                                                        <w:anchorlock/>\n                                                        <center style=\"color:#ffffff;font-family:Arial,Helvetica,sans-serif;font-size:16px;font-weight:bold;\">Become a Member</center>\n                                                    </v:roundrect>\n                                                    <![endif]-->\n                                                    <!--[if !mso]><!-->\n                                                    <a class=\"vcBtnRed\" href=\"https://www.same.org/membership-communities/join/\" style=\"display: inline-block; background-color: #C41E3A; color: #FFFFFF !important; font-family: Arial, Helvetica, sans-serif; font-size: 16px; font-weight: bold; text-decoration: none !important; padding: 14px 36px; border-radius: 24px; line-height: 1.2;\">Become a Member</a>\n                                                    <!--<![endif]-->\n                                                ",
  "save_date_heading": "\n                                        <p style=\"margin: 0 0 8px 0; font-family: Arial, Helvetica, sans-serif; font-size: 12px; font-weight: bold; color: #003478; line-height: 1.3; text-transform: uppercase; letter-spacing: 1.5px;\">SAVE THE DATE</p>\n                                        <h2 class=\"vcHeading\" style=\"margin: 0 0 16px 0; font-family: Georgia, 'Times New Roman', Times, serif; font-size: 24px; font-weight: bold; color: #003478; line-height: 1.3;\">Annual Golf Tournament 2026</h2>\n                                        ",
  "save_date_callout": "\n                                                                <p style=\"margin: 0; font-family: Georgia, 'Times New Roman', Times, serif; font-size: 28px; font-weight: bold; color: #FFFFFF; line-height: 1.3;\">July 2026</p>\n                                                                <p style=\"margin: 8px 0 0 0; font-family: Arial, Helvetica, sans-serif; font-size: 14px; color: #FFFFFF; line-height: 1.4; opacity: 0.85;\">Exact date coming soon</p>\n                                                            ",
  "save_date_body": "\n                                        <p style=\"margin: 0; font-family: Arial, Helvetica, sans-serif; font-size: 16px; color: #374151; line-height: 1.6; text-align: center;\">Our biggest fundraiser of the year is back. Sponsorship packages and early registration details coming soon. Mark your calendars now!</p>\n                                        ",
  "save_date_button": "\n                                                    <!--[if mso]>\n                                                    <v:roundrect xmlns:v=\"urn:schemas-microsoft-com:vml\" xmlns:w=\"urn:schemas-microsoft-com:office:word\" href=\"mailto:samesanfrancisco@gmail.com?subject=Golf%20Tournament%20Interest\" style=\"height:48px;v-text-anchor:middle;width:260px;\" arcsize=\"50%\" fillcolor=\"#C41E3A\" stroke=\"f\">\n                                                        <w:anchorlock/>\n                                                        <center style=\"color:#ffffff;font-family:Arial,Helvetica,sans-serif;font-size:16px;font-weight:bold;\">I'm Interested!</center>\n                                                    </v:roundrect>\n                                                    <![endif]-->\n                                                    <!--[if !mso]><!-->\n                                                    <a class=\"vcBtnRed\" href=\"mailto:samesanfrancisco@gmail.com?subject=Golf%20Tournament%20Interest\" style=\"display: inline-block; background-color: #C41E3A; color: #FFFFFF !important; font-family: Arial, Helvetica, sans-serif; font-size: 16px; font-weight: bold; text-decoration: none !important; padding: 14px 36px; border-radius: 24px; line-height: 1.2;\">I'm Interested!</a>\n                                                    <!--<![endif]-->\n                                                ",
  "events_heading": "\n                                        <p style=\"margin: 0 0 8px 0; font-family: Arial, Helvetica, sans-serif; font-size: 12px; font-weight: bold; color: #C41E3A; line-height: 1.3; text-transform: uppercase; letter-spacing: 1.5px;\">WHAT'S AHEAD</p>\n                                        <h2 class=\"vcHeading\" style=\"margin: 0 0 24px 0; font-family: Georgia, 'Times New Roman', Times, serif; font-size: 24px; font-weight: bold; color: #003478; line-height: 1.3;\">2026 at a Glance</h2>\n                                        ",
  "event_date_1": "MAR 12",
  "event_desc_1": "\n                                                    <p style=\"margin: 0; font-family: Arial, Helvetica, sans-serif; font-size: 15px; color: #374151; line-height: 1.5;\"><strong>USCG Industry Day</strong> &mdash; Free, CEU Oakland</p>\n                                                ",
  "event_date_2": "APR TBD",
  "event_desc_2": "\n                                                    <p style=\"margin: 0; font-family: Arial, Helvetica, sans-serif; font-size: 15px; color: #374151; line-height: 1.5;\"><strong>Monthly Meeting w/Speaker</strong> &mdash; Marines' Memorial</p>\n                                                ",
  "event_date_3": "JUN TBD",
  "event_desc_3": "\n                                                    <p style=\"margin: 0; font-family: Arial, Helvetica, sans-serif; font-size: 15px; color: #374151; line-height: 1.5;\"><strong>Tinker Fest</strong> &mdash; USCG partnership event</p>\n                                                ",
  "event_date_4": "JUL TBD",
  "event_desc_4": "\n                                                    <p style=\"margin: 0; font-family: Arial, Helvetica, sans-serif; font-size: 15px; color: #374151; line-height: 1.5;\"><strong>Annual Golf Tournament</strong> &mdash; STEM scholarship fundraiser</p>\n                                                ",
  "event_date_5": "SEP TBD",
  "event_desc_5": "\n                                                    <p style=\"margin: 0; font-family: Arial, Helvetica, sans-serif; font-size: 15px; color: #374151; line-height: 1.5;\"><strong>A/E/C AI &amp; Cybersecurity Summit</strong> &mdash; Multi-day summit</p>\n                                                ",
  "event_date_6": "SEP TBD",
  "event_desc_6": "\n                                                    <p style=\"margin: 0; font-family: Arial, Helvetica, sans-serif; font-size: 15px; color: #374151; line-height: 1.5;\"><strong>Member Appreciation Day</strong> &mdash; Annual member recognition</p>\n                                                ",
  "event_date_7": "DEC 10",
  "event_desc_7": "\n                                                    <p style=\"margin: 0; font-family: Arial, Helvetica, sans-serif; font-size: 15px; color: #374151; line-height: 1.5;\"><strong>Annual Holiday Gala</strong> &mdash; Scholarship awards celebration</p>\n                                                ",
  "events_closing": "\n                                        <p style=\"margin: 24px 0 24px 0; font-family: Arial, Helvetica, sans-serif; font-size: 16px; color: #374151; line-height: 1.6;\">Stay tuned for more details!</p>\n                                        ",
  "events_button": "\n                                                    <!--[if mso]>\n                                                    <v:roundrect xmlns:v=\"urn:schemas-microsoft-com:vml\" xmlns:w=\"urn:schemas-microsoft-com:office:word\" href=\"https://www.same.org/sf/events/\" style=\"height:48px;v-text-anchor:middle;width:220px;\" arcsize=\"50%\" fillcolor=\"#C41E3A\" stroke=\"f\">\n                                                        <w:anchorlock/>\n                                                        <center style=\"color:#ffffff;font-family:Arial,Helvetica,sans-serif;font-size:16px;font-weight:bold;\">See All Events</center>\n                                                    </v:roundrect>\n                                                    <![endif]-->\n                                                    <!--[if !mso]><!-->\n                                                    <a class=\"vcBtnRed\" href=\"https://www.same.org/sf/events/\" style=\"display: inline-block; background-color: #C41E3A; color: #FFFFFF !important; font-family: Arial, Helvetica, sans-serif; font-size: 16px; font-weight: bold; text-decoration: none !important; padding: 14px 36px; border-radius: 24px; line-height: 1.2;\">See All Events</a>\n                                                    <!--<![endif]-->\n                                                ",
  "footer_heading": "Let's Stay Connected",
