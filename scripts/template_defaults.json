  "stem_heading": "\n                                        <p style=\"margin: 0 0 8px 0; font-family: Arial, Helvetica, sans-serif; font-size: 12px; font-weight: bold; color: #C41E3A; line-height: 1.3; text-transform: uppercase; letter-spacing: 1.5px;\">STEM &amp; SCHOLARSHIPS</p>\n                                        <h2 class=\"vcHeading\" style=\"margin: 0 0 16px 0; font-family: Georgia, 'Times New Roman', Times, serif; font-size: 24px; font-weight: bold; color: #003478; line-height: 1.3;\">Investing in the Next Generation</h2>\n                                        ",
  "stem_image": "\n                                                    <img src=\"https://mcusercontent.com/c4247c59958d5b480b1e708d2/images/0bf35464-23d6-5b0a-05a7-91cafdf47305.jpg\" alt=\"STEM and scholarship program\" width=\"556\" style=\"display: block; width: 100%; max-width: 556px; height: auto; border: 0; border-radius: 4px;\">\n                                                ",
  "stem_body": "\n                                        <p style=\"margin: 0 0 16px 0; font-family: Arial, Helvetica, sans-serif; font-size: 16px; color: #374151; line-height: 1.6;\">Our scholarship program continues to grow, funding future engineers and leaders across the Bay Area. Through partnerships with USF and the Jonathan Cartwright Endowment, we're helping bridge the gap between academic potential and professional opportunity.</p>\n                                        <p style=\"margin: 0 0 16px 0; font-family: Arial, Helvetica, sans-serif; font-size: 16px; color: #374151; line-height: 1.6;\">Whether it's mentoring, sponsoring a student, or contributing to the endowment, there's a role for everyone in building the next generation of A/E/C leaders.</p>\n                                        <p style=\"margin: 0; font-family: Arial, Helvetica, sans-serif; font-size: 14px; color: #003478; line-height: 1.5; background-color: #F0F4FF; padding: 12px 16px; border-radius: 4px; border-left: 3px solid #003478;\"><strong>Did you know?</strong> Military, government, and student SAME members get <strong>FREE registration</strong> to JETC (Joint Engineer Training Conference) &mdash; the premier annual event for the military engineering community.</p>\n                                        ",
  "stem_button": "\n                                                    <!--[if mso]>\n                                                    <v:roundrect xmlns:v=\"urn:schemas-microsoft-com:vml\" xmlns:w=\"urn:schemas-microsoft-com:office:word\" href=\"https://www.same.org/sf/scholarships/\" style=\"height:48px;v-text-anchor:middle;width:200px;\" arcsize=\"50%\" fillcolor=\"#C41E3A\" stroke=\"f\">\n                                                        <w:anchorlock/>\n                                                        <center style=\"color:#ffffff;font-family:Arial,Helvetica,sans-serif;font-size:16px;font-weight:bold;\">Learn More</center>\n                                                    </v:roundrect>\n                                                    <![endif]-->\n                                                    <!--[if !mso]><!-->\n                                                    <a class=\"vcBtnRed\" href=\"https://www.same.org/sf/scholarships/\" style=\"display: inline-block; background-color: #C41E3A; color: #FFFFFF !important; font-family: Arial, Helvetica, sans-serif; font-size: 16px; font-weight: bold; text-decoration: none !important; padding: 14px 36px; border-radius: 24px; line-height: 1.2;\">Learn More</a>\n                                                    <!--<![endif]-->\n                                                ",
  "engineers_week_heading": "\n                                        <p style=\"margin: 0 0 8px 0; font-family: Arial, Helvetica, sans-serif; font-size: 12px; font-weight: bold; color: #C41E3A; line-height: 1.3; text-transform: uppercase; letter-spacing: 1.5px;\">COMMUNITY</p>\n                                        <h2 class=\"vcHeading\" style=\"margin: 0 0 16px 0; font-family: Georgia, 'Times New Roman', Times, serif; font-size: 24px; font-weight: bold; color: #003478; line-height: 1.3;\">It's National Engineers Week!</h2>\n                                        ",
  "engineers_week_body": "\n                                        <p style=\"margin: 0 0 16px 0; font-family: Arial, Helvetica, sans-serif; font-size: 16px; color: #374151; line-height: 1.6;\">National Engineers Week (February 16&ndash;22) just wrapped up, and we wanted to take a moment to recognize the engineers who design, build, and protect the infrastructure we all depend on.</p>\n\n                                        <p style=\"margin: 0 0 16px 0; font-family: Arial, Helvetica, sans-serif; font-size: 16px; color: #374151; line-height: 1.6;\">At SAME SF, we connect military, government, and private-sector engineers year-round. From site visits and technical forums to STEM scholarships and mentorship, our work lives at the intersection of engineering and national service.</p>\n\n                                        <p style=\"margin: 0; font-family: Arial, Helvetica, sans-serif; font-size: 16px; color: #374151; line-height: 1.6;\">To every engineer in our network: this week is yours. And if you know someone who should be part of our community, now's a great time to invite them.</p>\n                                        ",
  "engineers_week_button": "\n                                                    <!--[if mso]>\n                                                    <v:roundrect xmlns:v=\"urn:schemas-microsoft-com:vml\" xmlns:w=\"urn:schemas-microsoft-com:office:word\" href=\"https://www.asce.org/education-and-events/events/meetings/engineers-week\" style=\"height:48px;v-text-anchor:middle;width:200px;\" arcsize=\"50%\" fillcolor=\"#C41E3A\" stroke=\"f\">\n                                                        <w:anchorlock/>\n                                                        <center style=\"color:#ffffff;font-family:Arial,Helvetica,sans-serif;font-size:16px;font-weight:bold;\">Learn More</center>\n                                                    </v:roundrect>\n                                                    <![endif]-->\n                                                    <!--[if !mso]><!-->\n                                                    <a class=\"vcBtnRed\" href=\"https://www.asce.org/education-and-events/events/meetings/engineers-week\" style=\"display: inline-block; background-color: #C41E3A; color: #FFFFFF !important; font-family: Arial, Helvetica, sans-serif; font-size: 16px; font-weight: bold; text-decoration: none !important; padding: 14px 36px; border-radius: 24px; line-height: 1.2;\">Learn More</a>\n                                                    <!--<![endif]-->\n                                                ",
  "news_heading": "\n                                        <p style=\"margin: 0 0 8px 0; font-family: Arial, Helvetica, sans-serif; font-size: 12px; font-weight: bold; color: #C41E3A; line-height: 1.3; text-transform: uppercase; letter-spacing: 1.5px;\">INDUSTRY NEWS</p>\n                                        <h2 class=\"vcHeading\" style=\"margin: 0 0 20px 0; font-family: Georgia, 'Times New Roman', Times, serif; font-size: 24px; font-weight: bold; color: #003478; line-height: 1.3;\">Worth Your Attention</h2>\n                                        ",
  "news_item_1": "\n                                                    <p style=\"margin: 0 0 4px 0; font-family: Arial, Helvetica, sans-serif; font-size: 16px; font-weight: bold; color: #003478; line-height: 1.4;\"><a href=\"#\" style=\"color: #003478; text-decoration: underline;\">Article Title Goes Here &rarr;</a></p>\n                                                    <p style=\"margin: 0; font-family: Arial, Helvetica, sans-serif; font-size: 14px; color: #6B7280; line-height: 1.5;\">Brief description of the article and why it matters to the A/E/C community.</p>\n                                                ",
